<resources>
    <!-- Base application theme. -->
    <style name="Theme.Mobiware" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="fontFamily">@font/dosis_medium</item>
        <item name="colorPrimary">@color/orange</item>
        <item name="colorPrimaryVariant">@color/main</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" >?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>


    <style name="Theme.SpecialButton" parent="ThemeOverlay.Material3.Button">
        <item name="cornerRadius">@dimen/_12sdp</item>
        <item name="backgroundTint">@color/orange</item>
    </style>

    <style name="Theme.SpecialTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopEnd">@dimen/_15sdp</item>
        <item name="boxCornerRadiusTopStart">@dimen/_15sdp</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/_15sdp</item>
        <item name="boxCornerRadiusBottomStart">@dimen/_15sdp</item>
    </style>
</resources>